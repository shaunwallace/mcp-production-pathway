# Copy this file to .env in your workbook and fill in the values.
# .env is gitignored — never commit real secrets.

# Required for the harness (Week 2 onwards)
ANTHROPIC_API_KEY=sk-ant-...

# Backend credentials — fill in the one(s) matching your Week 2 backend choice.
# See weeks/week-00-setup.md for the menu.
GITHUB_TOKEN=ghp_...
LINEAR_API_KEY=lin_api_...
NOTION_API_KEY=ntn_...
TODOIST_API_TOKEN=...
TRELLO_API_KEY=...
TRELLO_TOKEN=...

# Optional: override the default Claude model (see docs/model-ids.md)
# CLAUDE_MODEL=claude-sonnet-4-6
